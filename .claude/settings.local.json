{
  "permissions": {
    "allow": [
      "PowerShell(netstat *)",
      "PowerShell(Set-ExecutionPolicy *)",
      "PowerShell(New-Item *)",
      "WebFetch(domain:api.anthropic.com)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Start-Sleep -Seconds 5; try { $r = Invoke-WebRequest -Uri \"http://localhost:8081\" -TimeoutSec 5 -UseBasicParsing; \"Status: $\\($r.StatusCode\\)\" } catch { \"Error: $_\" })"
    ]
  }
}
